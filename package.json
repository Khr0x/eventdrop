{
  "name": "eventdrop",
  "version": "0.1.0",
  "description": "Serverless API to manage events and webhooks",
  "private": true,
  "scripts": {
    "build": "sam build",
    "deploy": "sam deploy --guided",
    "delete": "sam delete",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "esbuild": "^0.21.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^22.20.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
